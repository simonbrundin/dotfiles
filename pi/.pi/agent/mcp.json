{
  "mcpServers": {
    "context-mode": {
      "command": "context-mode"
    },
"nuxt": {
      "command": "npx",
      "args": ["mcp-remote", "https://nuxt.com/mcp"]
    },
    "flux-operator-mcp": {
      "command": "flux-operator-mcp",
      "args": ["serve", "--read-only=false"],
      "env": {
        "KUBECONFIG": "/tmp/kubeconfig-certificate"
      }
    }
  }
}